{
  "name": "@littlebearapps/outlook-assistant",
  "version": "3.4.1",
  "mcpName": "io.github.littlebearapps/outlook-assistant",
  "description": "Outlook Assistant — MCP server with 20 tools for email, calendar, contacts, and settings via Microsoft Graph API",
  "main": "index.js",
  "bin": {
    "outlook-assistant": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "auth-server": "node outlook-auth-server.js",
    "test-mode": "USE_TEST_MODE=true node index.js",
    "inspect": "npx @modelcontextprotocol/inspector node index.js",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "version": "node -e \"const s=require('./server.json');const p=require('./package.json');s.version=p.version;s.packages[0].version=p.version;require('fs').writeFileSync('./server.json',JSON.stringify(s,null,2)+'\\n')\" && git add server.json"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "claude",
    "outlook",
    "mcp",
    "microsoft-graph",
    "email",
    "calendar",
    "contacts",
    "model-context-protocol",
    "anthropic"
  ],
  "author": "Little Bear Apps <hello@littlebearapps.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/littlebearapps/outlook-assistant.git"
  },
  "homepage": "https://littlebearapps.com/builds/outlook-assistant",
  "bugs": {
    "url": "https://github.com/littlebearapps/outlook-assistant/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.js",
    "config.js",
    "outlook-auth-server.js",
    "auth/",
    "calendar/",
    "categories/",
    "contacts/",
    "email/",
    "folder/",
    "rules/",
    "settings/",
    "advanced/",
    "utils/",
    ".env.example",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "overrides": {
    "minimatch": ">=3.1.3"
  }
}
